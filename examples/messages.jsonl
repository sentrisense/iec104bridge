# Example IEC-104 bridge input messages – DLR (Dynamic Line Rating) demo
#
# Format: one JSON object per line.  Blank lines and lines starting with '#'
# are ignored.
#
# IOA addressing scheme (matches the NATS publisher and scraper):
#   CA  = power line number (1 or 2)
#   IOA 1001–1010  → span 1–10 conductor temperature  (M_ME_NC_1, float, °C)
#   IOA 2001–2010  → span 1–10 ampacity               (M_ME_NB_1, scaled, A)
#   IOA 3001       → line ampacity = min of valid span ampacities (M_ME_NB_1, A)
#
# Quality states: good | not_topical | substituted | blocked | overflow | invalid
# Spans 9 & 10 carry degraded quality to exercise the state-timeline panels.

# ── Power Line 1 (CA=1) ───────────────────────────────────────────────────────
# Span temperatures (M_ME_NC_1)
{"ca": 1, "ioa": 1001, "type": "float", "value": 67.43, "quality": "good"}
{"ca": 1, "ioa": 1002, "type": "float", "value": 65.81, "quality": "good"}
{"ca": 1, "ioa": 1003, "type": "float", "value": 68.12, "quality": "good"}
{"ca": 1, "ioa": 1004, "type": "float", "value": 66.55, "quality": "good"}
{"ca": 1, "ioa": 1005, "type": "float", "value": 67.03, "quality": "good"}
{"ca": 1, "ioa": 1006, "type": "float", "value": 64.78, "quality": "good"}
{"ca": 1, "ioa": 1007, "type": "float", "value": 66.99, "quality": "good"}
{"ca": 1, "ioa": 1008, "type": "float", "value": 65.44, "quality": "good"}
{"ca": 1, "ioa": 1009, "type": "float", "value": 67.20, "quality": "not_topical"}
{"ca": 1, "ioa": 1010, "type": "float", "value": 66.01, "quality": "invalid"}
# Span ampacities (M_ME_NB_1)
{"ca": 1, "ioa": 2001, "type": "scaled", "value": 503, "quality": "good"}
{"ca": 1, "ioa": 2002, "type": "scaled", "value": 517, "quality": "good"}
{"ca": 1, "ioa": 2003, "type": "scaled", "value": 498, "quality": "good"}
{"ca": 1, "ioa": 2004, "type": "scaled", "value": 511, "quality": "good"}
{"ca": 1, "ioa": 2005, "type": "scaled", "value": 506, "quality": "good"}
{"ca": 1, "ioa": 2006, "type": "scaled", "value": 522, "quality": "good"}
{"ca": 1, "ioa": 2007, "type": "scaled", "value": 507, "quality": "good"}
{"ca": 1, "ioa": 2008, "type": "scaled", "value": 515, "quality": "good"}
{"ca": 1, "ioa": 2009, "type": "scaled", "value": 505, "quality": "not_topical"}
{"ca": 1, "ioa": 2010, "type": "scaled", "value": 509, "quality": "invalid"}
# Line ampacity = min of valid spans (span 3 @ 498 A)
{"ca": 1, "ioa": 3001, "type": "scaled", "value": 498, "quality": "good"}

